{
  "@context": [
    "https://www.w3.org/ns/solid/oidc-context.jsonld",
    {
      "fedapp": "https://w3id.org/jeswr/fed#",
      "acl": "http://www.w3.org/ns/auth/acl#",
      "sectors": "https://w3id.org/jeswr/sectors/",
      "App": "fedapp:App",
      "sector": {
        "@id": "fedapp:sector",
        "@type": "@id"
      },
      "access": {
        "@id": "fedapp:access",
        "@type": "@id",
        "@container": "@set"
      },
      "consumes": {
        "@id": "fedapp:consumes",
        "@type": "@id",
        "@container": "@set"
      },
      "produces": {
        "@id": "fedapp:produces",
        "@type": "@id",
        "@container": "@set"
      }
    }
  ],
  "client_id": "https://excalidraw-solid.vercel.app/clientid.jsonld",
  "client_name": "Excalidraw (Solid edition)",
  "client_uri": "https://excalidraw-solid.vercel.app/",
  "logo_uri": "https://excalidraw-solid.vercel.app/favicon.ico",
  "redirect_uris": [
    "https://excalidraw-solid.vercel.app/",
    "https://excalidraw-solid.vercel.app/callback.html"
  ],
  "grant_types": [
    "authorization_code",
    "refresh_token"
  ],
  "response_types": [
    "code"
  ],
  "scope": "openid profile offline_access webid",
  "token_endpoint_auth_method": "none",
  "@type": "App",
  "sector": "https://w3id.org/jeswr/sectors/drawing#sector",
  "access": [
    "acl:Read",
    "acl:Write",
    "acl:Control"
  ],
  "produces": [
    "https://w3id.org/jeswr/drawing#Scene"
  ],
  "consumes": [
    "https://w3id.org/jeswr/drawing#Scene"
  ]
}
